{
  "schema": "evidence-gate.test-vectors/1",
  "comment": [
    "Shared cross-port test vectors. Loaded by BOTH test/vectors.test.mjs (JS)",
    "and python/tests/test_core.py (Python). Records/rules/expectations are",
    "written in the JS port's camelCase convention; the Python harness maps",
    "keys via its KEY_MAP (staleDays -> stale_days, qualityScore ->",
    "quality_score, ...). Every `evidenceDigest` expectation uses only",
    "port-neutral record keys (date/tier/flags/quality), so the digest MUST",
    "be byte-identical across the two ports. Do not edit expected values to",
    "make a port pass — a mismatch here means the ports have diverged."
  ],
  "fnv1a64": [
    { "input": "", "expected": "cbf29ce484222325" },
    { "input": "a", "expected": "af63dc4c8601ec8c" },
    { "input": "foobar", "expected": "85944171f73967e8" },
    { "input": "สวัสดี", "expected": "3e0dcf56d00e781a" }
  ],
  "canonicalJson": [
    {
      "name": "sorted-keys-unicode-kept",
      "value": { "b": 2, "a": [1, "é", true], "z": null },
      "expected": "{\"a\":[1,\"é\",true],\"b\":2,\"z\":null}"
    },
    {
      "name": "nested-object-thai-float",
      "value": { "z": { "b": 1, "a": [true, false, null] }, "k": "สวัสดี", "n": 1.5 },
      "expected": "{\"k\":\"สวัสดี\",\"n\":1.5,\"z\":{\"a\":[true,false,null],\"b\":1}}"
    },
    { "name": "empty-object", "value": {}, "expected": "{}" },
    { "name": "empty-array", "value": [], "expected": "[]" },
    { "name": "plain-array", "value": [1, 2, 3], "expected": "[1,2,3]" }
  ],
  "digest": [
    {
      "name": "shared-reference-object",
      "value": { "b": 2, "a": [1, "é", true], "z": null },
      "expected": "fnv1a64:2a4b821432ab8bcc"
    },
    {
      "name": "nested-object-thai-float",
      "value": { "z": { "b": 1, "a": [true, false, null] }, "k": "สวัสดี", "n": 1.5 },
      "expected": "fnv1a64:8cc778cdb3a6aad9"
    },
    { "name": "empty-object", "value": {}, "expected": "fnv1a64:08f44b07b5901a25" },
    { "name": "plain-array", "value": [1, 2, 3], "expected": "fnv1a64:28bbee4398699f19" },
    {
      "name": "empty-evidence-set",
      "value": { "records": [], "supporting": [] },
      "expected": "fnv1a64:b154377d61167670"
    }
